---
import BaseLayout from "../layouts/BaseLayout.astro";
import PictureSlot from "../components/PictureSlot.astro";
---

<BaseLayout
  title="聯絡"
  description="聯絡靜初苑，可透過 LINE、Instagram 或預留表單欄位詢問服務。"
>
  <section class="page">
    <div class="container split">
      <div>
        <p class="eyebrow">CONTACT</p>
        <h1>聯絡與預約</h1>
        <p class="lead">
          目前建議先以 LINE 官方帳號作為主要聯絡管道。表單區已先預留，後續可接 Cloudflare Worker 並發送 LINE 通知。
        </p>
        <div class="button-row">
          <button class="button" type="button" data-line-dialog-open aria-label="加入 LINE 官方帳號">
            加入 LINE
          </button>
          <a
            class="button secondary"
            href="https://www.instagram.com/jing_chu_yuan?utm_source=ig_web_button_share_sheet&igsh=ZDNlZDc0MzIxNw=="
            aria-label="前往 Instagram"
            target="_blank"
            rel="noreferrer"
          >
            Instagram
          </a>
        </div>
      </div>
      <PictureSlot
        src="/images/contact/contact.webp"
        alt="靜初苑聯絡與預約意象"
        label="聯絡頁圖片預留"
      />
    </div>
  </section>

  <section class="band">
    <div class="container split">
      <div>
        <p class="eyebrow">FORM PREVIEW</p>
        <h2>聯絡表單預留</h2>
        <p>
          這份表單目前是前端版型，尚未接後端。下一階段可以把內容送到 LINE 官方帳號，並同步備份到 Google Sheet 或 Cloudflare D1。
        </p>
      </div>
      <form class="card" action="#" method="post">
        <label>
          姓名或暱稱
          <input type="text" name="name" placeholder="請輸入姓名或暱稱" />
        </label>
        <label>
          偏好的聯絡方式
          <select name="contact_type">
            <option value="">請選擇</option>
            <option>LINE ID</option>
            <option>電話</option>
            <option>Email</option>
            <option>Instagram</option>
          </select>
        </label>
        <label>
          聯絡資料
          <input type="text" name="contact_value" placeholder="請填寫帳號、電話或 Email" />
        </label>
        <label>
          想聊的方向
          <textarea name="message" placeholder="可簡單說明目前需求，選填即可"></textarea>
        </label>
        <button class="button" type="button" data-form-dialog-open>送出表單</button>
      </form>
    </div>
  </section>

</BaseLayout>

<script>
  document.querySelector("[data-line-dialog-open]")?.addEventListener("click", () => {
    alert("請先提供 LINE 官方帳號名稱、加入好友連結或 LINE ID，之後會把這個按鈕改成直接加入官方帳號。");
  });

  document.querySelector("[data-form-dialog-open]")?.addEventListener("click", () => {
    alert("目前表單尚未啟用，還不會真的送出資料。正式啟用前需要先確認資料要通知到 LINE、Email 或 Google Sheet。");
  });
</script>
