---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "靜初苑服務網站，提供服務介紹、常見問題與聯絡方式。",
} = Astro.props;

const navItems = [
  { href: "/", label: "首頁" },
  { href: "/service/", label: "服務介紹" },
  { href: "/about/", label: "關於我" },
  { href: "/faq/", label: "FAQ" },
  { href: "/contact/", label: "聯絡" },
];

const footerItems = [
  { href: "/service/", label: "服務介紹" },
  { href: "/faq/", label: "常見問題" },
  { href: "/contact/", label: "聯絡預約" },
];
---

<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | 靜初苑</title>
  </head>
  <body>
    <header>
      <div class="brand-bar">
        <a class="brand" href="/">
          <span>靜初苑</span>
          <small>JING CHU YUAN</small>
        </a>
      </div>
      <nav class="site-nav" aria-label="主要導覽">
        {navItems.map((item) => <a href={item.href} data-nav-link>{item.label}</a>)}
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <a class="brand footer-brand" href="/">
          <span>靜初苑</span>
          <small>JING CHU YUAN</small>
        </a>
        <p>人生的答案就在你願意看見自己的那一刻顯現。</p>
        <div class="footer-links">
          {footerItems.map((item) => <a href={item.href} data-nav-link>{item.label}</a>)}
        </div>
        <p class="copyright">© 2026 靜初苑</p>
      </div>
    </footer>
    <script>
      const currentPath = window.location.pathname;

      document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]").forEach((link) => {
        const href = link.getAttribute("href");
        const isActive = href === "/" ? currentPath === "/" : Boolean(href && currentPath.startsWith(href));

        link.classList.toggle("is-active", isActive);

        if (isActive) {
          link.setAttribute("aria-current", "page");
        } else {
          link.removeAttribute("aria-current");
        }
      });
    </script>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: light;
    --color-bg: #fdfcf9;
    --color-surface: #ffffff;
    --color-soft: #f5f1ea;
    --color-text: #302b25;
    --color-muted: #706a62;
    --color-line: #e4ded3;
    --color-gold: #bd9252;
    --color-gold-dark: #8f6935;
    --color-sage: #8c9b83;
    --color-sage-dark: #58674f;
    --space-page: clamp(20px, 5vw, 48px);
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    background: var(--color-bg);
    color: var(--color-text);
    line-height: 1.7;
  }

  a {
    color: inherit;
  }

  .brand-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 118px;
    padding: 28px var(--space-page) 22px;
    background: var(--color-surface);
  }

  .brand {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    color: var(--color-gold);
    text-decoration: none;
    text-transform: uppercase;
  }

  .brand span {
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 400;
    letter-spacing: 0.22em;
    line-height: 1.1;
  }

  .brand small {
    margin-top: 8px;
    color: var(--color-muted);
    font-size: 11px;
    letter-spacing: 0.32em;
  }

  .site-nav {
    position: sticky;
    top: 0;
    z-index: 10;
    display: flex;
    justify-content: center;
    gap: 0;
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    background: rgba(253, 252, 249, 0.94);
    backdrop-filter: blur(10px);
  }

  .site-nav a {
    position: relative;
    padding: 13px 30px;
    border-left: 1px solid transparent;
    border-right: 1px solid transparent;
    color: var(--color-muted);
    font-size: 15px;
    text-decoration: none;
  }

  .site-nav a:hover,
  .site-nav a.is-active {
    color: var(--color-gold-dark);
    background: var(--color-soft);
  }

  .site-nav a.is-active::after {
    position: absolute;
    right: 22px;
    bottom: -1px;
    left: 22px;
    height: 2px;
    background: var(--color-gold);
    content: "";
  }

  main {
    min-height: 70vh;
  }

  section,
  .page {
    padding: 72px var(--space-page);
  }

  .container {
    width: min(100%, 1080px);
    margin: 0 auto;
  }

  .narrow {
    width: min(100%, 760px);
    margin: 0 auto;
  }

  .eyebrow {
    margin: 0 0 8px;
    color: var(--color-gold);
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }

  h1,
  h2,
  h3,
  p {
    margin-top: 0;
  }

  h1 {
    max-width: 820px;
    margin-bottom: 20px;
    color: var(--color-gold-dark);
    font-size: clamp(34px, 7vw, 58px);
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1.2;
  }

  h2 {
    margin-bottom: 18px;
    color: var(--color-gold-dark);
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 400;
    letter-spacing: 0.04em;
    line-height: 1.25;
  }

  h3 {
    margin-bottom: 8px;
    color: var(--color-text);
    font-size: 20px;
    font-weight: 500;
  }

  p {
    color: var(--color-muted);
  }

  .lead {
    max-width: 680px;
    font-size: 19px;
  }

  .button-row {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 28px;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 46px;
    padding: 10px 18px;
    border: 1px solid var(--color-gold);
    border-radius: 2px;
    background: var(--color-gold);
    color: #fff;
    font-size: 14px;
    letter-spacing: 0.12em;
    text-decoration: none;
    text-transform: uppercase;
  }

  .button:hover {
    background: var(--color-gold-dark);
    border-color: var(--color-gold-dark);
  }

  .button.secondary {
    background: transparent;
    color: var(--color-gold-dark);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 22px;
  }

  .card {
    padding: 28px;
    border: 1px solid var(--color-line);
    border-radius: 2px;
    background: var(--color-surface);
  }

  .split {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 420px);
    gap: clamp(32px, 6vw, 72px);
    align-items: center;
  }

  .image-slot {
    position: relative;
    display: grid;
    min-height: 340px;
    place-items: center;
    overflow: hidden;
    border: 1px solid var(--color-line);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.76), rgba(245, 241, 234, 0.86)),
      radial-gradient(circle at 20% 24%, rgba(191, 146, 82, 0.22), transparent 25%),
      radial-gradient(circle at 78% 40%, rgba(140, 155, 131, 0.24), transparent 28%);
    color: var(--color-muted);
    font-size: 13px;
    letter-spacing: 0.2em;
    text-align: center;
    text-transform: uppercase;
  }

  .image-slot img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-slot span {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 10px;
    max-width: 280px;
    padding: 18px;
    background: rgba(255, 255, 255, 0.7);
  }

  .image-slot small {
    color: #9a948b;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: none;
    word-break: break-all;
  }

  .image-slot.is-loaded {
    background: #fff;
  }

  .image-slot.is-loaded span {
    display: none;
  }

  .image-slot.tall {
    min-height: 520px;
  }

  .band {
    background: var(--color-soft);
  }

  .center {
    text-align: center;
  }

  .center .lead,
  .center h1,
  .center h2 {
    margin-left: auto;
    margin-right: auto;
  }

  .list {
    display: grid;
    gap: 14px;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .list li {
    padding: 14px 0;
    border-bottom: 1px solid var(--color-line);
    color: var(--color-muted);
  }

  label {
    display: grid;
    gap: 8px;
    color: var(--color-text);
    font-size: 14px;
  }

  input,
  textarea,
  select {
    width: 100%;
    border: 1px solid var(--color-line);
    border-radius: 2px;
    background: #fff;
    color: var(--color-text);
    font: inherit;
    padding: 12px 14px;
  }

  textarea {
    min-height: 132px;
    resize: vertical;
  }

  form {
    display: grid;
    gap: 16px;
  }

  .site-footer {
    padding: 56px var(--space-page);
    border-top: 1px solid var(--color-line);
    background: var(--color-surface);
    text-align: center;
  }

  .footer-inner {
    width: min(100%, 760px);
    margin: 0 auto;
  }

  .footer-brand span {
    font-size: 24px;
  }

  .footer-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 18px;
    margin: 24px 0;
    color: var(--color-muted);
    font-size: 14px;
  }

  .footer-links a {
    position: relative;
    padding-bottom: 4px;
    text-decoration: none;
  }

  .footer-links a:hover,
  .footer-links a.is-active {
    color: var(--color-gold-dark);
  }

  .footer-links a.is-active::after {
    position: absolute;
    right: 0;
    bottom: 0;
    left: 0;
    height: 1px;
    background: var(--color-gold);
    content: "";
  }

  .site-footer p {
    margin: 0;
    font-size: 14px;
  }

  .copyright {
    color: #9a948b;
  }

  @media (max-width: 640px) {
    .brand-bar {
      min-height: 96px;
    }

    .brand span {
      font-size: 28px;
      letter-spacing: 0.16em;
    }

    .site-nav {
      justify-content: flex-start;
      overflow-x: auto;
    }

    .site-nav a {
      flex: 0 0 auto;
      padding: 12px 18px;
      font-size: 14px;
    }

    section,
    .page {
      padding-top: 42px;
      padding-bottom: 42px;
    }

    .split {
      grid-template-columns: 1fr;
    }

    .image-slot,
    .image-slot.tall {
      min-height: 260px;
    }
  }
</style>
